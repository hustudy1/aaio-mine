# 노션 협업 워크스페이스 등록 — notion.yaml.example
#
# 본 파일은 placeholder. 실제 노션 워크스페이스 URL 은 본인 fork 안 `config/notion.yaml`
# (gitignored) 에만 두고, repo 본문/PR/이슈에 URL 그대로 publish 안 한다.
#
# 노션 layer 자체의 거버넌스 규칙은 docs/explanation/notion-collab-layer.md 참조.
#
# 본 파일을 본인 fork 안에서 `config/notion.yaml` 로 복사한 뒤 빈 칸 채움.

notion:
  workspace_url: "<your-notion-workspace-url>"      # 예: app.notion.com/p/<owner>/<page-id>
  owner: "<owner-handle-or-name>"                   # 노션 워크스페이스 owner (사용자 본인 또는 다른 멤버)
  members:                                          # 접근 권한 받은 멤버 list (이름 또는 handle)
    - "<member-1>"
    - "<member-2>"
  role: collaboration-view-only                     # view-only / no-source-of-truth (고정값)
  schema_version: "1.0"

# 안전선 (notion-collab-layer.md §4 hard constraint 그대로 — 본 파일은 reminder 만):
#
# 1. 회사 코드 · 시스템 정보 · 고객 정보 · 사내 운영 데이터 절대 안 들어감 (반출 0)
# 2. HSH 등 본인 personal 자산 lineage 안 들어감
# 3. OO Mode A 본체 SSOT 본문 안 들어감 (private_root, internal-sensitive)
# 4. 노션 = view, source-of-truth 아님. 결정 · 액션 아이템은 task JSON / WP / git 으로 옮김.
